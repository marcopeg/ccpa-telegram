---
const today = new Date();
---

<footer>
	<div class="footer-container">
		<div class="footer-left">
			<a href="/">HAL &copy; {today.getFullYear()}</a>
		</div>
		<div class="footer-center">
			<a href="/about">About</a>
			<span class="separator">•</span>
			<a href="/rss.xml">RSS</a>
			<span class="separator">•</span>
			<a href="/cookies">Cookies</a>
		</div>
		<div class="footer-right">
			<span>Powered by Astro Build</span>
		</div>
	</div>
</footer>
<style>
	footer {
		background-color: #0d0d0d;
		color: #b3b3b3;
		padding: 8rem 2rem;
		margin: 6rem 0 0 0;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.footer-left,
	.footer-center,
	.footer-right {
		font-size: 1.15rem;
	}

	.footer-left a {
		color: #b3b3b3;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.footer-left a:hover {
		color: #ffffff;
	}

	.footer-center {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.footer-center a {
		color: #b3b3b3;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.footer-center a:hover {
		color: #ffffff;
	}

	.separator {
		color: #666;
		padding: 0 0.25rem;
	}

	@media (max-width: 768px) {
		footer {
			padding: 3rem 1.5rem;
		}

		.footer-container {
			flex-direction: column;
			text-align: center;
			gap: 1rem;
		}

		.footer-left,
		.footer-right {
			width: 100%;
		}
	}
</style>
