---
// Note component - displays content with blue left border (original blockquote style)
---

<div class="note-container">
	<div class="note-content">
		<slot />
	</div>
</div>

<style>
	.note-container {
		margin: max(4.8vmin, 32px) 0;
		position: relative;
	}

	.note-content {
		position: relative;
		font-family: Georgia, Times, serif;
		font-weight: 400;
		font-size: 2rem;
		line-height: 1.6em;
		color: #15171a;
		font-style: italic;
		padding-left: 1.5em;
	}

	.note-content::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 0.3rem;
		background: var(--accent, #1b9cff);
	}

	.note-content :global(p) {
		margin: 0;
		font-size: inherit;
		line-height: inherit;
		color: inherit;
	}

	.note-content :global(p + p) {
		margin-top: 1em;
	}

	@media (max-width: 650px) {
		.note-content {
			font-size: 1.8rem;
		}

		.note-content::before {
			left: min(-4vmin, -20px);
		}
	}
</style>
